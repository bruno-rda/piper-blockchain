  "components": {
    "schemas": {
      "AdminConfigRequest": {
        "properties": {
          "difficulty": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Difficulty"
          },
          "block_reward_coins": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Block Reward Coins"
          },
          "max_transactions_per_block": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Transactions Per Block"
          },
          "units_per_coin": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Units Per Coin"
          }
        },
        "type": "object",
        "title": "AdminConfigRequest"
      },
      "AdminInitRequest": {
        "properties": {
          "miner_address": {
            "type": "string",
            "title": "Miner Address"
          }
        },
        "type": "object",
        "required": ["miner_address"],
        "title": "AdminInitRequest"
      },
      "AdminTokenResponse": {
        "properties": {
          "session_token": {
            "type": "string",
            "title": "Session Token"
          }
        },
        "type": "object",
        "required": ["session_token"],
        "title": "AdminTokenResponse"
      },
      "AdminVerifyRequest": {
        "properties": {
          "admin_password": {
            "type": "string",
            "title": "Admin Password"
          }
        },
        "type": "object",
        "required": ["admin_password"],
        "title": "AdminVerifyRequest"
      },
      "BasicResponse": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Message"
          }
        },
        "type": "object",
        "required": ["success"],
        "title": "BasicResponse"
      },
      "BlockDetailResponse": {
        "properties": {
          "height": {
            "type": "integer",
            "title": "Height"
          },
          "hash": {
            "type": "string",
            "title": "Hash"
          },
          "previous_hash": {
            "type": "string",
            "title": "Previous Hash"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "tx_count": {
            "type": "integer",
            "title": "Tx Count"
          },
          "miner_address": {
            "type": "string",
            "title": "Miner Address"
          },
          "miner_username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Miner Username"
          },
          "nonce": {
            "type": "integer",
            "title": "Nonce"
          },
          "merkle_root": {
            "type": "string",
            "title": "Merkle Root"
          },
          "transactions": {
            "items": {
              "$ref": "#/components/schemas/TransactionDetailResponse"
            },
            "type": "array",
            "title": "Transactions"
          }
        },
        "type": "object",
        "required": [
          "height",
          "hash",
          "previous_hash",
          "timestamp",
          "tx_count",
          "miner_address",
          "nonce",
          "merkle_root",
          "transactions"
        ],
        "title": "BlockDetailResponse"
      },
      "BlockMiningRequest": {
        "properties": {
          "miner_wallet_address": {
            "type": "string",
            "title": "Miner Wallet Address"
          }
        },
        "type": "object",
        "required": ["miner_wallet_address"],
        "title": "BlockMiningRequest"
      },
      "BlockResponse": {
        "properties": {
          "height": {
            "type": "integer",
            "title": "Height"
          },
          "hash": {
            "type": "string",
            "title": "Hash"
          },
          "previous_hash": {
            "type": "string",
            "title": "Previous Hash"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "tx_count": {
            "type": "integer",
            "title": "Tx Count"
          },
          "miner_address": {
            "type": "string",
            "title": "Miner Address"
          },
          "miner_username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Miner Username"
          },
          "nonce": {
            "type": "integer",
            "title": "Nonce"
          },
          "merkle_root": {
            "type": "string",
            "title": "Merkle Root"
          }
        },
        "type": "object",
        "required": [
          "height",
          "hash",
          "previous_hash",
          "timestamp",
          "tx_count",
          "miner_address",
          "nonce",
          "merkle_root"
        ],
        "title": "BlockResponse"
      },
      "ConfigResponse": {
        "properties": {
          "difficulty": {
            "type": "integer",
            "title": "Difficulty"
          },
          "block_reward_coins": {
            "type": "integer",
            "title": "Block Reward Coins"
          },
          "max_tx_per_block": {
            "type": "integer",
            "title": "Max Tx Per Block"
          },
          "units_per_coin": {
            "type": "integer",
            "title": "Units Per Coin"
          },
          "coin_name": {
            "type": "string",
            "title": "Coin Name"
          },
          "unit_name": {
            "type": "string",
            "title": "Unit Name"
          }
        },
        "type": "object",
        "required": [
          "difficulty",
          "block_reward_coins",
          "max_tx_per_block",
          "units_per_coin",
          "coin_name",
          "unit_name"
        ],
        "title": "ConfigResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MempoolStatusResponse": {
        "properties": {
          "mining_active": {
            "type": "boolean",
            "title": "Mining Active"
          },
          "miner_address": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Miner Address"
          }
        },
        "type": "object",
        "required": ["mining_active"],
        "title": "MempoolStatusResponse"
      },
      "ResetRequest": {
        "properties": {
          "confirmation": {
            "type": "string",
            "title": "Confirmation"
          },
          "reset_profiles": {
            "type": "boolean",
            "title": "Reset Profiles"
          }
        },
        "type": "object",
        "required": ["confirmation", "reset_profiles"],
